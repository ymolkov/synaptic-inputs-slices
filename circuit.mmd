graph TD
    %% Nodes
    VI(VgluT2-I)
    VE(VgluT2-E)
    GI(VGAT-I)
    GE(VGAT-E)

    %% Styling
    style VI fill:#ffcccc,stroke:#ff0000,stroke-width:2px,color:black
    style VE fill:#ffcccc,stroke:#ff0000,stroke-width:2px,color:black
    style GI fill:#ccccff,stroke:#0000ff,stroke-width:2px,color:black
    style GE fill:#ccccff,stroke:#0000ff,stroke-width:2px,color:black

    %% Force Layout Ranks using a subgraph or invisible links if needed
    %% We want VI and VE at the top, GI and GE at the bottom.
    %% Usually defining them in order helps, but cyclic connections mess it up.
    %% Using a subgraph for alignment is a common trick.
    
    subgraph Top_Row [ ]
        direction LR
        VI
        VE
    end
    
    subgraph Bottom_Row [ ]
        direction LR
        GI
        GE
    end
            
    %% Hidden link to ensure Top is above Bottom
    VI ~~~ GI
    VE ~~~ GE

    %% Connections (No Labels)
    
    %% VGAT-E (GE) -> VI and GI
    GE --o VI
    GE --o GI

    %% VGAT-I (GI) -> VE and GE
    GI --o VE
    GI --o GE

    %% VgluT2-I (VI) -> VI (Loop) and GI
    VI --> VI
    VI --> GI

    %% Styling Links
    %% Indices depend on the order of definition.
    %% 0: GE->VI (Blue)
    %% 1: GE->GI (Blue)
    %% 2: GI->VE (Blue)
    %% 3: GI->GE (Blue)
    %% 4: VI->VI (Red)
    %% 5: VI->GI (Red)
    
    linkStyle 0,1,2,3 stroke:#0000ff,stroke-width:2px,fill:none;
    linkStyle 4,5 stroke:#ff0000,stroke-width:2px,fill:none;
    
    %% Hide the subgraph borders
    style Top_Row fill:none,stroke:none
    style Bottom_Row fill:none,stroke:none
